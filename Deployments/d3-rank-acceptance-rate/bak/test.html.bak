<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>大学录取率分析浏览器</title>
    <script src="https://d3js.org/d3.v7.min.js"></script>
    <style>
        :root {
            --public-color: #3498db;
            --private-color: #e67e22;
            --bg-color: #f4f7f9;
            --card-bg: #ffffff;
            --text-main: #2c3e50;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background-color: var(--bg-color);
            margin: 0;
            padding: 40px 20px;
            color: var(--text-main);
            display: flex;
            justify-content: center;
        }

        .container {
            width: 100%;
            max-width: 1100px;
            background: var(--card-bg);
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.06);
        }

        header {
            text-align: center;
            margin-bottom: 35px;
        }

        h1 { margin: 0; font-size: 26px; font-weight: 700; }
        .subtitle { color: #7f8c8d; margin-top: 8px; font-size: 14px; }

        /* 顶部控制区 */
        .controls {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 20px;
            margin-bottom: 40px;
            background: #fafafa;
            padding: 20px;
            border-radius: 12px;
        }

        .control-group { display: flex; align-items: center; gap: 10px; }

        select {
            padding: 10px 15px;
            border-radius: 8px;
            border: 1px solid #dfe6e9;
            font-size: 14px;
            outline: none;
            background: white;
            cursor: pointer;
        }

        select:focus { border-color: var(--public-color); }

        /* 图表区域 */
        #chart-area {
            width: 100%;
            min-height: 500px;
        }

        .bar {
            cursor: pointer;
            transition: opacity 0.2s;
        }

        .bar:hover { opacity: 0.8; }

        .label { font-size: 12px; fill: #555; }
        .value-label { font-size: 11px; fill: #7f8c8d; font-weight: 600; }

        .axis-label { font-size: 12px; color: #95a5a6; }
        
        /* 提示框 */
        #tooltip {
            position: absolute;
            background: rgba(44, 62, 80, 0.95);
            color: white;
            padding: 10px 15px;
            border-radius: 6px;
            font-size: 12px;
            pointer-events: none;
            display: none;
            z-index: 100;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        }

        .legend {
            display: flex;
            justify-content: center;
            gap: 30px;
            margin-top: 30px;
            font-size: 13px;
        }
        .legend-item { display: flex; align-items: center; gap: 6px; }
        .dot { width: 10px; height: 10px; border-radius: 50%; }
    </style>
</head>
<body>

<div class="container">
    <header>
        <h1>美国大学录取率浏览器</h1>
        <div class="subtitle">请选择州以查看该地区大学的详细录取率对比</div>
    </header>

    <div class="controls">
        <div class="control-group">
            <label>选择州：</label>
            <select id="state-select"></select>
        </div>
        <div class="control-group">
            <label>排序方式：</label>
            <select id="sort-select">
                <option value="rate-desc">录取率：从高到低</option>
                <option value="rate-asc">录取率：从低到高</option>
                <option value="name">校名拼音</option>
            </select>
        </div>
    </div>

    <div id="chart-area">
        <div id="tooltip"></div>
    </div>

    <div class="legend">
        <div class="legend-item"><div class="dot" style="background: var(--public-color);"></div> 公立大学</div>
        <div class="legend-item"><div class="dot" style="background: var(--private-color);"></div> 私立大学</div>
    </div>
</div>

<script>
    let fullData = [];
    const margin = {top: 10, right: 60, bottom: 30, left: 240};
    const chartContainer = d3.select("#chart-area");

    // 1. 加载数据
    d3.csv("./IPEDS_data.csv").then(data => {
        fullData = data.map(d => ({
            name: d.Name,
            state: d['State abbreviation'],
            type: d['Control of institution'].includes('Public') ? 'Public' : 'Private',
            rate: (+d['Admissions total'] / +d['Applicants total']) || 0,
            applicants: +d['Applicants total']
        })).filter(d => d.state && d.applicants > 0);

        // 填充州下拉菜单
        const states = Array.from(new Set(fullData.map(d => d.state))).sort();
        const stateSelect = d3.select("#state-select");
        states.forEach(s => stateSelect.append("option").text(s).attr("value", s));

        // 初始渲染
        updateChart();
    });

    // 2. 绘图函数
    function updateChart() {
        const selectedState = d3.select("#state-select").property("value");
        const sortBy = d3.select("#sort-select").property("value");

        // 过滤和排序数据
        let filtered = fullData.filter(d => d.state === selectedState);
        
        if (sortBy === "rate-desc") filtered.sort((a, b) => b.rate - a.rate);
        else if (sortBy === "rate-asc") filtered.sort((a, b) => a.rate - b.rate);
        else filtered.sort((a, b) => a.name.localeCompare(b.name));

        // 限制显示前 40 个，防止页面过长
        filtered = filtered.slice(0, 40);

        // 设置动态高度
        const rowHeight = 30;
        const width = chartContainer.node().clientWidth - margin.left - margin.right;
        const height = filtered.length * rowHeight;

        chartContainer.select("svg").remove();
        const svg = chartContainer.append("svg")
            .attr("width", width + margin.left + margin.right)
            .attr("height", height + margin.top + margin.bottom)
            .append("g")
            .attr("transform", `translate(${margin.left},${margin.top})`);

        // 比例尺
        const x = d3.scaleLinear().domain([0, 1]).range([0, width]);
        const y = d3.scaleBand().domain(filtered.map(d => d.name)).range([0, height]).padding(0.2);

        // 坐标轴
        svg.append("g")
            .attr("transform", `translate(0,${height})`)
            .call(d3.axisBottom(x).ticks(5, "%").tickSize(-height))
            .call(g => g.select(".domain").remove())
            .call(g => g.selectAll(".tick line").attr("stroke", "#eee"));

        svg.append("g")
            .call(d3.axisLeft(y).tickSize(0))
            .selectAll("text")
            .attr("class", "label");

        // 绘制柱条
        svg.selectAll(".bar")
            .data(filtered)
            .enter()
            .append("rect")
            .attr("class", "bar")
            .attr("y", d => y(d.name))
            .attr("x", 0)
            .attr("height", y.bandwidth())
            .attr("fill", d => d.type === 'Public' ? '#3498db' : '#e67e22')
            .attr("width", 0) // 动画起始值
            .on("mouseover", (e, d) => {
                d3.select("#tooltip")
                    .style("display", "block")
                    .html(`<strong>${d.name}</strong><br>录取率: ${(d.rate*100).toFixed(1)}%<br>类型: ${d.type}`);
            })
            .on("mousemove", (e) => {
                d3.select("#tooltip")
                    .style("left", (e.pageX + 15) + "px")
                    .style("top", (e.pageY - 15) + "px");
            })
            .on("mouseout", () => d3.select("#tooltip").style("display", "none"))
            .transition().duration(800)
            .attr("width", d => x(d.rate));

        // 数值标签
        svg.selectAll(".val-text")
            .data(filtered)
            .enter()
            .append("text")
            .attr("class", "value-label")
            .attr("y", d => y(d.name) + y.bandwidth()/2 + 4)
            .attr("x", d => x(d.rate) + 8)
            .text(d => (d.rate * 100).toFixed(1) + "%");
    }

    // 监听事件
    d3.select("#state-select").on("change", updateChart);
    d3.select("#sort-select").on("change", updateChart);
</script>

</body>
</html>