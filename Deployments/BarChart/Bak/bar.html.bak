<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Smart Categorical Explorer | GeoMap Style</title>
  <script src="https://d3js.org/d3.v7.min.js"></script>
  <style>
    /* Professional Layout & Colors */
    :root {
      --primary-color: #3498db;
      --bg-color: #f4f7f9;
      --card-bg: #ffffff;
      --text-dark: #2c3e50;
      --text-muted: #95a5a6;
      --accent-green: #2ecc71;
    }

    body {
      margin: 0;
      font-family: 'Inter', -apple-system, sans-serif;
      background-color: var(--bg-color);
      color: var(--text-dark);
      display: flex;
      justify-content: center;
      padding: 50px 20px;
    }

    .main-card {
      width: 100%;
      max-width: 1150px;
      background: var(--card-bg);
      border-radius: 24px;
      box-shadow: 0 15px 45px rgba(0,0,0,0.07);
      padding: 45px;
    }

    header { text-align: center; margin-bottom: 40px; }
    h1 { font-size: 32px; margin: 0; font-weight: 800; letter-spacing: -0.8px; }
    
    .status-tag {
      display: inline-block;
      margin-top: 15px;
      padding: 6px 18px;
      border-radius: 50px;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
    }
    .status-scanning { background: #e8f4fd; color: #3498db; }
    .status-ready { background: #eafaf1; color: var(--accent-green); }
    .status-error { background: #fdedec; color: #e74c3c; }

    /* Control Panel */
    .dashboard-controls {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: flex-end;
      gap: 25px;
      background: #fafbfc;
      padding: 30px;
      border-radius: 18px;
      border: 1px solid #f0f0f0;
      margin-bottom: 50px;
    }

    .input-field { display: flex; flex-direction: column; gap: 8px; }
    label { font-size: 11px; font-weight: 800; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; }

    select, input {
      padding: 12px 18px;
      border-radius: 12px;
      border: 1px solid #dfe6e9;
      font-size: 14px;
      background: #fff;
      transition: all 0.2s;
    }
    select:focus { border-color: var(--primary-color); outline: none; box-shadow: 0 0 0 4px rgba(52,152,219,0.1); }

    button#apply-btn {
      padding: 13px 35px;
      background: var(--primary-color);
      color: #fff;
      border: none;
      border-radius: 12px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s;
    }
    button#apply-btn:hover { background: #2980b9; transform: translateY(-1px); }

    /* Charting Area */
    #viz-container { width: 100%; min-height: 500px; position: relative; }
    .bar-rect { fill: var(--primary-color); rx: 6; }
    .axis-label { font-size: 12px; fill: #95a5a6; }
    .grid line { stroke: #f2f2f2; }

    /* Tooltip */
    #chart-tooltip {
      position: absolute;
      background: rgba(33, 47, 61, 0.98);
      color: #fff;
      padding: 12px 16px;
      border-radius: 10px;
      font-size: 13px;
      pointer-events: none;
      display: none;
      box-shadow: 0 8px 25px rgba(0,0,0,0.2);
      z-index: 100;
    }
  </style>
</head>
<body>

<div class="main-card">
  <header>
    <h1>Smart Categorical Analysis</h1>
    <div id="status-display" class="status-tag status-scanning">Analyzing IPEDS Columns...</div>
  </header>

  <div class="dashboard-controls">
    <div class="input-field">
      <label>Categorical Feature</label>
      <select id="column-dropdown"></select>
    </div>
    <div class="input-field">
      <label>Limit to Top N</label>
      <input type="number" id="top-n-limit" value="15" min="1" max="100" style="width: 80px;" />
    </div>
    <div class="input-field">
      <label>Chart Orientation</label>
      <select id="chart-mode">
        <option value="h">Horizontal (Best for names)</option>
        <option value="v">Vertical (Classic)</option>
      </select>
    </div>
    <button id="apply-btn">Generate Chart</button>
  </div>

  <div id="viz-container">
    <div id="chart-tooltip"></div>
  </div>
</div>

<script>
  let cachedData = [];
  const viz = d3.select("#viz-container");
  const tooltip = d3.select("#chart-tooltip");

  /**
   * ADVANCED CATEGORICAL DETECTION
   * Filters out: Percentages, Coordinates, Total Counts, and IDs.
   * Keeps: States (50+), Degrees, Affiliations, Years (limited), etc.
   */
  function autoDetectCategorical(data, col) {
    const samples = data.slice(0, 500).map(d => d[col]).filter(v => v !== "" && v !== undefined);
    if (samples.length === 0) return false;

    // Rule 1: If any value contains non-numeric characters (excluding decimal point), it's Categorical.
    const hasAlpha = samples.some(v => /[a-zA-Z]/.test(v));
    if (hasAlpha) return true;

    // Rule 2: If it's numeric, check the cardinality (unique count).
    // We increase threshold to 75 to safely include 50 States + US Territories + small numeric codes.
    const uniqueValues = new Set(samples);
    const isNumeric = samples.every(v => !isNaN(parseFloat(v)) && isFinite(v));

    // If it's numeric, but the variety is low, we treat it as a category (e.g., Year or FIPS Code).
    // If unique count is high (like percentage 0.12, 0.54, 0.99...), we reject it.
    return isNumeric && uniqueValues.size > 1 && uniqueValues.size <= 75;
  }

  function setStatus(text, type) {
    d3.select("#status-display").text(text).attr("class", "status-tag status-" + type);
  }

  function render(data, mode) {
    viz.select("svg").remove();
    const isH = mode === "h";
    
    const margin = { 
        top: 20, 
        right: 50, 
        bottom: isH ? 40 : 130, 
        left: isH ? 260 : 70 
    };
    
    const width = viz.node().clientWidth - margin.left - margin.right;
    const height = isH ? (data.length * 38) : 500;

    const svg = viz.append("svg")
      .attr("width", width + margin.left + margin.right)
      .attr("height", height + margin.top + margin.bottom)
      .append("g")
      .attr("transform", `translate(${margin.left},${margin.top})`);

    const xLimit = d3.max(data, d => d.value);

    if (isH) {
      const x = d3.scaleLinear().domain([0, xLimit]).range([0, width]);
      const y = d3.scaleBand().domain(data.map(d => d.label)).range([0, height]).padding(0.25);

      svg.append("g").attr("class", "grid").attr("transform", `translate(0,${height})`).call(d3.axisBottom(x).ticks(5).tickSize(-height));
      svg.append("g").call(d3.axisLeft(y).tickSize(0)).selectAll("text").attr("class", "axis-label");

      svg.selectAll(".bar-rect").data(data).enter().append("rect").attr("class", "bar-rect")
         .attr("y", d => y(d.label)).attr("height", y.bandwidth()).attr("x", 0)
         .on("mouseover", (e, d) => tooltip.style("display", "block").html(`<b>${d.label}</b><hr>Count: ${d.value}`))
         .on("mousemove", (e) => tooltip.style("left", (e.pageX + 15) + "px").style("top", (e.pageY - 15) + "px"))
         .on("mouseout", () => tooltip.style("display", "none"))
         .transition().duration(1000).attr("width", d => x(d.value));
    } else {
      const x = d3.scaleBand().domain(data.map(d => d.label)).range([0, width]).padding(0.3);
      const y = d3.scaleLinear().domain([0, xLimit]).range([height, 0]);

      svg.append("g").attr("class", "grid").call(d3.axisLeft(y).ticks(5).tickSize(-width));
      svg.append("g").attr("transform", `translate(0,${height})`).call(d3.axisBottom(x))
         .selectAll("text").attr("class", "axis-label").attr("transform", "rotate(-45)").style("text-anchor", "end");

      svg.selectAll(".bar-rect").data(data).enter().append("rect").attr("class", "bar-rect")
         .attr("x", d => x(d.label)).attr("width", x.bandwidth()).attr("y", height)
         .on("mouseover", (e, d) => tooltip.style("display", "block").html(`<b>${d.label}</b><hr>Count: ${d.value}`))
         .on("mousemove", (e) => tooltip.style("left", (e.pageX + 15) + "px").style("top", (e.pageY - 15) + "px"))
         .on("mouseout", () => tooltip.style("display", "none"))
         .transition().duration(1000).attr("y", d => y(d.value)).attr("height", d => height - y(d.value));
    }
  }

  async function appInit() {
    try {
      const data = await d3.csv("./IPEDS_data.csv");
      cachedData = data;
      
      const dropdown = d3.select("#column-dropdown");
      let validCols = 0;

      data.columns.forEach(col => {
        if (autoDetectCategorical(data, col)) {
          dropdown.append("option").attr("value", col).text(col);
          validCols++;
        }
      });

      setStatus(`Engine Ready: Found ${validCols} Categorical Features.`, "ready");

      d3.select("#apply-btn").on("click", () => {
        const col = d3.select("#column-dropdown").property("value");
        const n = +d3.select("#top-n-limit").property("value");
        const mode = d3.select("#chart-mode").property("value");
        
        const counts = d3.rollup(cachedData, v => v.length, d => d[col] || "Unknown");
        const processed = Array.from(counts, ([label, value]) => ({ label, value }))
                               .sort((a, b) => b.value - a.value)
                               .slice(0, n);

        render(processed, mode);
      });

    } catch (err) {
      setStatus("Error: Cannot reach CSV. Verify Local Server or Filename.", "error");
    }
  }

  appInit();
</script>
</body>
</html>