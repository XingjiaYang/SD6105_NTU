<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Numerical Histogram Explorer | GeoMap Style</title>
  <script src="https://d3js.org/d3.v7.min.js"></script>
  <style>
    /* Modern Professional Style */
    :root {
      --primary-blue: #3498db;
      --bg-gray: #f4f7f9;
      --card-bg: #ffffff;
      --text-dark: #2c3e50;
      --text-muted: #95a5a6;
      --bar-color: #3498db;
    }

    body {
      margin: 0;
      font-family: 'Inter', -apple-system, system-ui, sans-serif;
      background-color: var(--bg-gray);
      color: var(--text-dark);
      display: flex;
      justify-content: center;
      padding: 60px 20px;
    }

    .main-container {
      width: 100%;
      max-width: 1100px;
      background: var(--card-bg);
      border-radius: 24px;
      box-shadow: 0 15px 45px rgba(0,0,0,0.06);
      padding: 50px;
    }

    header { text-align: center; margin-bottom: 40px; }
    h1 { font-size: 32px; margin: 0; font-weight: 800; letter-spacing: -0.8px; }
    
    .status-pill {
      display: inline-block;
      margin-top: 15px;
      padding: 6px 18px;
      border-radius: 50px;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
    }
    .status-loading { background: #e8f4fd; color: #3498db; }
    .status-ready { background: #eafaf1; color: #2ecc71; }
    .status-error { background: #fdedec; color: #e74c3c; }

    /* Control Panel */
    .controls-panel {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: flex-end;
      gap: 25px;
      background: #fafbfc;
      padding: 30px;
      border-radius: 18px;
      border: 1px solid #f0f0f0;
      margin-bottom: 50px;
    }

    .control-item { display: flex; flex-direction: column; gap: 8px; }
    label { font-size: 11px; font-weight: 800; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; }

    select, input {
      padding: 12px 18px;
      border-radius: 12px;
      border: 1px solid #dfe6e9;
      font-size: 14px;
      background: #fff;
      outline: none;
      transition: all 0.2s;
    }
    select:focus, input:focus { border-color: var(--primary-blue); box-shadow: 0 0 0 4px rgba(52,152,219,0.1); }

    button#update-btn {
      padding: 13px 35px;
      background: var(--primary-blue);
      color: #fff;
      border: none;
      border-radius: 12px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s;
    }
    button#update-btn:hover { background: #2980b9; transform: translateY(-1px); }

    /* Visualization Area */
    #chart-area { width: 100%; min-height: 500px; position: relative; }
    .histogram-bar { fill: var(--bar-color); stroke: #fff; stroke-width: 1px; rx: 4px; }
    .histogram-bar:hover { fill: #2980b9; }
    
    .axis-label { font-size: 12px; fill: var(--text-muted); }
    .grid line { stroke: #f2f2f2; }

    /* Tooltip */
    #chart-tooltip {
      position: absolute;
      background: rgba(33, 47, 61, 0.98);
      color: #fff;
      padding: 12px 16px;
      border-radius: 10px;
      font-size: 13px;
      pointer-events: none;
      display: none;
      box-shadow: 0 8px 25px rgba(0,0,0,0.2);
      z-index: 100;
      line-height: 1.4;
    }
  </style>
</head>
<body>

<div class="main-container">
  <header>
    <h1>IPEDS Distribution Analysis</h1>
    <div id="status-display" class="status-pill status-loading">Analyzing Data Columns...</div>
  </header>

  <div class="controls-panel">
    <div class="control-item">
      <label>Numerical Variable</label>
      <select id="column-selector"></select>
    </div>
    <div class="control-item">
      <label>Number of Bins</label>
      <input type="number" id="bin-input" value="20" min="5" max="100" style="width: 80px;" />
    </div>
    <button id="update-btn">Generate Histogram</button>
  </div>

  <div id="chart-area">
    <div id="chart-tooltip"></div>
  </div>
</div>

<script>
  let rawIpedsData = [];
  const chartArea = d3.select("#chart-area");
  const tooltip = d3.select("#chart-tooltip");

  /**
   * DETECTION LOGIC: Numerical Columns
   * We exclude columns that are clearly strings (IDs, Names, States)
   * and keep anything that parses to numbers consistently.
   */
  function isNumerical(data, colName) {
    const samples = data.slice(0, 300).map(d => d[colName]).filter(v => v !== "" && v !== undefined);
    if (samples.length === 0) return false;

    // Check if values are numeric
    const allNumeric = samples.every(v => !isNaN(parseFloat(v)) && isFinite(v));
    
    // Check cardinality: Numerical data usually has many unique values
    // Categorical codes usually have very few (e.g., < 20)
    const uniqueCount = new Set(samples).size;

    return allNumeric && uniqueCount > 20;
  }

  function setStatus(text, type) {
    d3.select("#status-display").text(text).attr("class", "status-pill status-" + type);
  }

  function drawHistogram(data, colName, binCount) {
    chartArea.select("svg").remove();

    const margin = { top: 20, right: 30, bottom: 60, left: 60 };
    const width = chartArea.node().clientWidth - margin.left - margin.right;
    const height = 500 - margin.top - margin.bottom;

    const svg = chartArea.append("svg")
      .attr("width", width + margin.left + margin.right)
      .attr("height", height + margin.top + margin.bottom)
      .append("g")
      .attr("transform", `translate(${margin.left},${margin.top})`);

    // Prepare numerical values
    const values = data.map(d => +d[colName]).filter(v => !isNaN(v));

    // X axis: scale and draw
    const x = d3.scaleLinear()
      .domain(d3.extent(values))
      .range([0, width])
      .nice();

    svg.append("g")
      .attr("transform", `translate(0,${height})`)
      .call(d3.axisBottom(x).tickSizeOuter(0))
      .attr("class", "axis-label");

    // Histogram binning
    const histogram = d3.bin()
      .domain(x.domain())
      .thresholds(x.ticks(binCount));

    const bins = histogram(values);

    // Y axis: scale and draw
    const y = d3.scaleLinear()
      .range([height, 0])
      .domain([0, d3.max(bins, d => d.length)])
      .nice();

    svg.append("g")
      .attr("class", "grid")
      .call(d3.axisLeft(y).ticks(8).tickSize(-width))
      .call(g => g.select(".domain").remove());

    // Draw bars
    svg.selectAll(".histogram-bar")
      .data(bins)
      .enter()
      .append("rect")
      .attr("class", "histogram-bar")
      .attr("x", d => x(d.x0) + 1)
      .attr("width", d => Math.max(0, x(d.x1) - x(d.x0) - 1))
      .attr("y", height) // start for animation
      .attr("height", 0)
      .on("mouseover", (e, d) => {
        tooltip.style("display", "block").html(`
          <strong>Range:</strong> ${d.x0.toFixed(2)} - ${d.x1.toFixed(2)}<br/>
          <strong>Count:</strong> ${d.length} institutions
        `);
      })
      .on("mousemove", (e) => {
        tooltip.style("left", (e.pageX + 15) + "px").style("top", (e.pageY - 15) + "px");
      })
      .on("mouseout", () => tooltip.style("display", "none"))
      .transition().duration(1000)
      .attr("y", d => y(d.length))
      .attr("height", d => height - y(d.length));

    // Axis Title
    svg.append("text")
       .attr("text-anchor", "middle")
       .attr("x", width/2)
       .attr("y", height + 50)
       .style("font-size", "14px")
       .style("font-weight", "600")
       .style("fill", "#2c3e50")
       .text(colName);
  }

  // Initialization
  async function init() {
    try {
      const data = await d3.csv("./IPEDS_data.csv");
      rawIpedsData = data;
      
      const dropdown = d3.select("#column-selector");
      let numericalCols = 0;

      data.columns.forEach(col => {
        if (isNumerical(data, col)) {
          dropdown.append("option").attr("value", col).text(col);
          numericalCols++;
        }
      });

      if (numericalCols > 0) {
        setStatus(`Found ${numericalCols} Numerical Columns.`, "ready");
      } else {
        setStatus("No Numerical columns detected.", "error");
      }

      d3.select("#update-btn").on("click", () => {
        const col = d3.select("#column-selector").property("value");
        const bins = +d3.select("#bin-input").property("value");
        if (col) drawHistogram(rawIpedsData, col, bins);
      });

    } catch (err) {
      setStatus("Error: CSV Load Failed. Use Local Server.", "error");
      console.error(err);
    }
  }

  init();
</script>
</body>
</html>